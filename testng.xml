<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Formy Automation Suite" parallel="none">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="env" value="qa"/>

    <test name="Regression Tests - Chrome QA">
        <classes>
            <class name="com.epam.automation.test.AutocompleteTest"/>
            <class name="com.epam.automation.test.CompleteWebFormTest"/>
            <class name="com.epam.automation.test.SwitchWindowTest"/>
        </classes>
    </test>

</suite>